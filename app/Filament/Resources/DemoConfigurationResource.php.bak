<?php

namespace App\Filament\Resources;

use App\Filament\Resources\DemoConfigurationResource\Pages;
use App\Filament\Resources\DemoConfigurationResource\RelationManagers;
use App\Models\DemoConfiguration;
use App\Models\Game;
use App\Services\DemoSimulationService;
use Filament\Forms;
use Filament\Forms\Form;
use Filament\Resources\Resource;
use Filament\Tables;
use Filament\Tables\Table;
use Filament\Notifications\Notification;
use Illuminate\Database\Eloquent\Builder;
use Illuminate\Database\Eloquent\SoftDeletingScope;

class DemoConfigurationResource extends Resource
{
    protected static ?string $model = DemoConfiguration::class;

    protected static ?string $navigationIcon = 'heroicon-o-chart-bar';

    protected static ?string $navigationLabel = 'Mode Démo';

    protected static ?string $modelLabel = 'Configuration Démo';

    protected static ?string $pluralModelLabel = 'Configurations Démo';

    protected static ?string $navigationGroup = 'Démonstration';

    protected static ?int $navigationSort = 1;

    public static function form(Form $form): Form
    {
        return $form
            ->schema([
                Forms\Components\Section::make('Informations Générales')
                    ->schema([
                        Forms\Components\Select::make('user_id')
                            ->label('Utilisateur')
                            ->relationship('user', 'name')
                            ->searchable()
                            ->preload()
                            ->required()
                            ->columnSpan(1),
                        Forms\Components\TextInput::make('name')
                            ->label('Nom de la configuration')
                            ->required()
                            ->maxLength(255)
                            ->columnSpan(1),
                        Forms\Components\Toggle::make('is_active')
                            ->label('Activer cette configuration')
                            ->default(true)
                            ->helperText('Désactive automatiquement les autres configurations pour cet utilisateur')
                            ->columnSpan(2),
                        Forms\Components\Textarea::make('description')
                            ->label('Description')
                            ->rows(3)
                            ->columnSpanFull(),
                    ])
                    ->columns(2),

                Forms\Components\Section::make('Période & Jeux')
                    ->schema([
                        Forms\Components\Select::make('period_type')
                            ->label('Type de période')
                            ->options([
                                'daily' => 'Quotidien',
                                'weekly' => 'Hebdomadaire',
                                'monthly' => 'Mensuel',
                            ])
                            ->default('daily')
                            ->required()
                            ->columnSpan(2),
                        Forms\Components\DatePicker::make('start_date')
                            ->label('Date de début')
                            ->required()
                            ->default(now())
                            ->columnSpan(1),
                        Forms\Components\DatePicker::make('end_date')
                            ->label('Date de fin (optionnelle)')
                            ->after('start_date')
                            ->columnSpan(1),
                        Forms\Components\CheckboxList::make('selected_games')
                            ->label('Jeux sélectionnés')
                            ->options(Game::where('is_active', true)->pluck('name', 'id'))
                            ->searchable()
                            ->bulkToggleable()
                            ->gridDirection('row')
                            ->columns(3)
                            ->columnSpanFull()
                            ->helperText('Laissez vide pour utiliser tous les jeux actifs'),
                    ])
                    ->columns(4),

                Forms\Components\Section::make('Configuration des Paris')
                    ->schema([
                        Forms\Components\TextInput::make('daily_bet_count')
                            ->label('Nombre de paris par jour')
                            ->required()
                            ->numeric()
                            ->minValue(1)
                            ->maxValue(1000)
                            ->default(10)
                            ->suffix('paris/jour'),
                        Forms\Components\TextInput::make('win_rate')
                            ->label('Taux de victoire (%)')
                            ->required()
                            ->numeric()
                            ->minValue(0)
                            ->maxValue(100)
                            ->default(45)
                            ->suffix('%')
                            ->helperText('Pourcentage de paris gagnants'),
                    ])
                    ->columns(2),

                Forms\Components\Section::make('Montants des Paris')
                    ->schema([
                        Forms\Components\TextInput::make('min_bet')
                            ->label('Mise minimale')
                            ->required()
                            ->numeric()
                            ->minValue(1)
                            ->default(100)
                            ->prefix('FCFA'),
                        Forms\Components\TextInput::make('max_bet')
                            ->label('Mise maximale')
                            ->required()
                            ->numeric()
                            ->minValue(1)
                            ->default(10000)
                            ->prefix('FCFA'),
                    ])
                    ->columns(2),

                Forms\Components\Section::make('Multiplicateurs de Gain')
                    ->schema([
                        Forms\Components\TextInput::make('min_win_multiplier')
                            ->label('Multiplicateur minimum')
                            ->required()
                            ->numeric()
                            ->minValue(1)
                            ->default(1.5)
                            ->suffix('x')
                            ->step(0.1),
                        Forms\Components\TextInput::make('max_win_multiplier')
                            ->label('Multiplicateur maximum')
                            ->required()
                            ->numeric()
                            ->minValue(1)
                            ->default(10)
                            ->suffix('x')
                            ->step(0.1),
                    ])
                    ->columns(2),
            ]);
    }

    public static function table(Table $table): Table
    {
        return $table
            ->columns([
                Tables\Columns\TextColumn::make('user.name')
                    ->label('Utilisateur')
                    ->searchable()
                    ->sortable(),
                Tables\Columns\TextColumn::make('name')
                    ->label('Nom')
                    ->searchable()
                    ->sortable()
                    ->weight('bold'),
                Tables\Columns\IconColumn::make('is_active')
                    ->label('Actif')
                    ->boolean()
                    ->sortable(),
                Tables\Columns\TextColumn::make('period_type')
                    ->label('Période')
                    ->badge()
                    ->color(fn (string $state): string => match ($state) {
                        'daily' => 'success',
                        'weekly' => 'warning',
                        'monthly' => 'info',
                        default => 'gray',
                    })
                    ->formatStateUsing(fn (string $state): string => match ($state) {
                        'daily' => 'Quotidien',
                        'weekly' => 'Hebdomadaire',
                        'monthly' => 'Mensuel',
                        default => $state,
                    }),
                Tables\Columns\TextColumn::make('start_date')
                    ->label('Début')
                    ->date('d/m/Y')
                    ->sortable(),
                Tables\Columns\TextColumn::make('end_date')
                    ->label('Fin')
                    ->date('d/m/Y')
                    ->sortable()
                    ->default('En cours'),
                Tables\Columns\TextColumn::make('win_rate')
                    ->label('Taux victoire')
                    ->suffix('%')
                    ->sortable()
                    ->alignCenter(),
                Tables\Columns\TextColumn::make('daily_bet_count')
                    ->label('Paris/jour')
                    ->numeric()
                    ->sortable()
                    ->alignCenter(),
                Tables\Columns\TextColumn::make('simulatedData_count')
                    ->label('Données générées')
                    ->counts('simulatedData')
                    ->badge()
                    ->color('success')
                    ->sortable(),
                Tables\Columns\TextColumn::make('created_at')
                    ->label('Créé le')
                    ->dateTime('d/m/Y H:i')
                    ->sortable()
                    ->toggleable(isToggledHiddenByDefault: true),
            ])
            ->filters([
                Tables\Filters\SelectFilter::make('is_active')
                    ->label('Statut')
                    ->options([
                        '1' => 'Actif',
                        '0' => 'Inactif',
                    ]),
                Tables\Filters\SelectFilter::make('period_type')
                    ->label('Type de période')
                    ->options([
                        'daily' => 'Quotidien',
                        'weekly' => 'Hebdomadaire',
                        'monthly' => 'Mensuel',
                    ]),
                Tables\Filters\TrashedFilter::make(),
            ])
            ->actions([
                Tables\Actions\Action::make('generate')
                    ->label('Générer')
                    ->icon('heroicon-o-sparkles')
                    ->color('success')
                    ->requiresConfirmation()
                    ->modalHeading('Générer les données de simulation')
                    ->modalDescription('Voulez-vous générer les données simulées pour cette configuration ?')
                    ->action(function (DemoConfiguration $record) {
                        try {
                            $service = app(DemoSimulationService::class);
                            $data = $service->generateData($record);

                            Notification::make()
                                ->title('Données générées avec succès')
                                ->body(count($data) . ' jours de données ont été générés.')
                                ->success()
                                ->send();
                        } catch (\Exception $e) {
                            Notification::make()
                                ->title('Erreur lors de la génération')
                                ->body($e->getMessage())
                                ->danger()
                                ->send();
                        }
                    }),
                Tables\Actions\Action::make('clear')
                    ->label('Effacer')
                    ->icon('heroicon-o-trash')
                    ->color('danger')
                    ->requiresConfirmation()
                    ->modalHeading('Effacer les données de simulation')
                    ->modalDescription('Êtes-vous sûr de vouloir effacer toutes les données simulées ?')
                    ->action(function (DemoConfiguration $record) {
                        try {
                            $service = app(DemoSimulationService::class);
                            $deleted = $service->clearData($record);

                            Notification::make()
                                ->title('Données effacées')
                                ->body($deleted . ' enregistrements ont été supprimés.')
                                ->success()
                                ->send();
                        } catch (\Exception $e) {
                            Notification::make()
                                ->title('Erreur lors de la suppression')
                                ->body($e->getMessage())
                                ->danger()
                                ->send();
                        }
                    }),
                Tables\Actions\EditAction::make(),
                Tables\Actions\DeleteAction::make(),
            ])
            ->bulkActions([
                Tables\Actions\BulkActionGroup::make([
                    Tables\Actions\DeleteBulkAction::make(),
                    Tables\Actions\ForceDeleteBulkAction::make(),
                    Tables\Actions\RestoreBulkAction::make(),
                ]),
            ])
            ->defaultSort('created_at', 'desc');
    }

    public static function getRelations(): array
    {
        return [
            //
        ];
    }

    public static function getPages(): array
    {
        return [
            'index' => Pages\ListDemoConfigurations::route('/'),
            'create' => Pages\CreateDemoConfiguration::route('/create'),
            'edit' => Pages\EditDemoConfiguration::route('/{record}/edit'),
        ];
    }
}
